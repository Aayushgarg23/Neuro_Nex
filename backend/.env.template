# NeuroNex Real-Time Configuration
# Copy this file to .env and fill in your credentials.

# ---------------------------------------------------------------------------
# 1. AI Provider Configuration
# Choose which AI to power the multi-agent system.
# Options: 'gemini', 'huggingface'
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini

# If using Gemini (Recommended for free tier, highly capable):
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# If using HuggingFace:
# Get your token at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2


# ---------------------------------------------------------------------------
# 2. Knowledge Graph Database
# Options: 'memory' (local JSON fallback) or 'neo4j' (live database)
# ---------------------------------------------------------------------------
GRAPH_REPO=memory

# If using Neo4j (e.g., Neo4j Aura Free Tier):
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
